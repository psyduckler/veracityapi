{
  "name": "@veracityapi/sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for VeracityAPI content trust scoring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "veracityapi",
    "content-trust",
    "ai-detection",
    "moderation",
    "typescript",
    "sdk"
  ],
  "homepage": "https://veracityapi.com/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/psyduckler/veracityapi.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/psyduckler/veracityapi/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
